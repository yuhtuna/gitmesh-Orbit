# =============================================================================
# GitMesh — Environment Variables Reference
# =============================================================================
# Copy this to .env and fill in your keys for local development.
#
# WHERE EACH KEY LIVES (production):
# ┌──────────────────────┬──────────────────────────────────────┐
# │ Key                  │ Location                             │
# ├──────────────────────┼──────────────────────────────────────┤
# │ GEMINI_API_KEY       │ Modal Secret "gitmesh-keys"          │
# │ MODAL_TOKEN_ID       │ GitLab CI/CD Variables               │
# │ MODAL_TOKEN_SECRET   │ GitLab CI/CD Variables               │
# │ GITLAB_API_TOKEN     │ GitLab CI/CD Variables               │
# │ GITLAB_PRIVATE_TOKEN │ .env only (for agent.py MCP local)   │
# └──────────────────────┴──────────────────────────────────────┘
# =============================================================================

# Gemini API key — used by modal_app.py for prompt enhancement & labeling
GEMINI_API_KEY="your-gemini-key-here"

# GitLab Personal Access Token — used by agent.py for MCP connection
GITLAB_PRIVATE_TOKEN="your-gitlab-pat-here"

# App URL (for Cloud Run / AI Studio deployment)
APP_URL="your-app-url-here"
