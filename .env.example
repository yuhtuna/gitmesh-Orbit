# =============================================================================
# GitMesh — Environment Variables Reference
# =============================================================================
# Copy this to .env and fill in your keys for local development.
#
# AUTH STRATEGY:
# - Default provider is Vertex AI.
# - GEMINI_API_KEY is optional local fallback only.
# - LLM_PROVIDER controls provider selection: vertex | gemini | auto.
#
# WHERE EACH KEY LIVES (production):
# ┌──────────────────────────┬──────────────────────────────────────┐
# │ Key                      │ Location                             │
# ├──────────────────────────┼──────────────────────────────────────┤
# │ GCP_PROJECT_ID           │ Modal Secret "gitmesh-keys" / CI vars│
# │ GCP_SERVICE_ACCOUNT_JSON │ Modal Secret "gitmesh-keys"          │
# │ GCP_ACCESS_TOKEN         │ Optional short-lived local token     │
# │ GEMINI_API_KEY           │ Optional fallback (local only)       │
# │ MODAL_TOKEN_ID           │ GitLab CI/CD Variables               │
# │ MODAL_TOKEN_SECRET       │ GitLab CI/CD Variables               │
# │ GITLAB_API_TOKEN         │ GitLab CI/CD Variables               │
# │ GITLAB_PROJECT_ID        │ Modal Secret "gitmesh-keys" / webhook│
# │ GITLAB_TRIGGER_TOKEN     │ GitLab CI/CD Variables / webhook     │
# │ GITLAB_WEBHOOK_SECRET    │ GitLab CI/CD Variables / webhook     │
# │ GITLAB_TRIGGER_REF       │ GitLab CI/CD Variables / webhook     │
# │ USE_ADK_ORCHESTRATOR     │ GitLab CI/CD Variables               │
# │ ADK_HARD_FAIL            │ GitLab CI/CD Variables               │
# │ PIPELINE_DRY_RUN         │ GitLab CI/CD Variables               │
# │ GITLAB_URL               │ Modal Secret / setup automation       │
# │ WEBHOOK_URL              │ setup automation override (optional)  │
# │ GITLAB_PRIVATE_TOKEN     │ .env only (for agent.py MCP local)   │
# └──────────────────────────┴──────────────────────────────────────┘
# =============================================================================

# Vertex AI project id used by modal_app.py (required)
GCP_PROJECT_ID="your-gcp-project-id"

# LLM provider mode:
# - vertex: Vertex AI only (default)
# - gemini: Gemini API only
# - auto: Vertex first, then Gemini fallback
LLM_PROVIDER="vertex"

# Image model preference (newer + cost-effective default):
# - gemini-3.1-flash-image (recommended for images)
# - gemini-3.5-flash
# - imagen-4.0-fast-generate-001
# - imagen-4.0-generate-001
# - imagen-3.0-generate-002 / imagen-3.0-generate-001
IMAGE_MODEL="gemini-3.1-flash-image"

# Optional: short-lived token for local testing if ADC is not available
# Example generation command:
# gcloud auth application-default print-access-token
GCP_ACCESS_TOKEN=""

# Remote production: service-account JSON stored in Modal Secret "gitmesh-keys".
# Prefer this over GCP_ACCESS_TOKEN for unattended GitLab-triggered runs.
GCP_SERVICE_ACCOUNT_JSON=""

# Optional fallback Gemini API key — used only when Vertex call is unavailable
GEMINI_API_KEY="your-gemini-key-here"

# GitLab Personal Access Token — used by agent.py for MCP connection
GITLAB_PRIVATE_TOKEN="your-gitlab-pat-here"

# Remote GitLab project id used by webhook trigger and Modal issue comments/uploads
GITLAB_PROJECT_ID="your-gitlab-project-id"

# Optional: GitLab base URL (set for self-managed GitLab; default is https://gitlab.com)
GITLAB_URL="https://gitlab.com"

# Remote pipeline trigger + webhook configuration
GITLAB_TRIGGER_TOKEN="your-gitlab-pipeline-trigger-token"
GITLAB_WEBHOOK_SECRET="your-gitlab-webhook-secret"
GITLAB_TRIGGER_REF="main"

# Remote orchestration controls
# USE_ADK_ORCHESTRATOR=true makes GitLab CI run the ADK orchestrator first.
# ADK_HARD_FAIL=false keeps the legacy direct Modal chain as rollback during migration.
# PIPELINE_DRY_RUN=false is required for real product-quality generation runs.
USE_ADK_ORCHESTRATOR="true"
ADK_HARD_FAIL="false"
PIPELINE_DRY_RUN="false"

# Optional: explicitly set deployed webhook endpoint if auto-detect fails in setup_remote.ps1
WEBHOOK_URL=""

# GitLab CI / Modal operator credentials
MODAL_TOKEN_ID="your-modal-token-id"
MODAL_TOKEN_SECRET="your-modal-token-secret"
GITLAB_API_TOKEN="your-gitlab-api-token"

# App URL (for Cloud Run / AI Studio deployment)
APP_URL="your-app-url-here"
